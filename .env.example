# ==================== AXIOM TRADE CREDENTIALS ====================
# Get tokens from https://axiom.trade
# Token authentication method (recommended for production)
AXIOM_ACCESS_TOKEN=your_access_token_here
AXIOM_REFRESH_TOKEN=your_refresh_token_here

# ==================== APPLICATION SETTINGS ====================
APP_NAME=Token Scanner
APP_VERSION=1.0.0
APP_DEBUG=false
APP_LOG_LEVEL=INFO

# ==================== DATABASE ====================
DATABASE_PATH=data/scanner.db
DATABASE_BACKUP_PATH=data/backups

# ==================== BROWSER AUTOMATION ====================
# Automatically open browser when token matches
BROWSER_AUTO_OPEN=true
# Open in new tab instead of new window
BROWSER_NEW_TAB=true
# Browser headless mode
BROWSER_HEADLESS=true

# ==================== NOTIFICATIONS ====================
# Desktop system notifications
NOTIFY_DESKTOP=true
# Audio notification sound
NOTIFY_SOUND=true
# Show popup window on match
NOTIFY_POPUP=true

# ==================== API SETTINGS ====================
# HTTP request timeout (seconds)
API_TIMEOUT=30
# Maximum retry attempts for failed requests
API_MAX_RETRIES=3
# WebSocket reconnection delay (seconds)
WS_RECONNECT_DELAY=5
# Maximum reconnection attempts
WS_MAX_RECONNECTS=10

# ==================== DEFAULT FILTERS ====================
# Minimum successful migrations
FILTER_MIN_SUCCESSFUL_MIGRATIONS=1
# Maximum tokens created
FILTER_MAX_CREATED_TOKENS=100
# Minimum success rate (%)
FILTER_MIN_SUCCESS_RATE=0.0
# Minimum liquidity (SOL)
FILTER_MIN_LIQUIDITY_SOL=2.0
# Minimum market cap (USD)
FILTER_MIN_MARKET_CAP_USD=0
# Maximum market cap (USD)
FILTER_MAX_MARKET_CAP_USD=10000000
# Minimum holders
FILTER_MIN_HOLDERS=10
# Maximum dev ownership (%)
FILTER_MAX_DEV_OWNERSHIP=50.0
# Only migrated tokens
FILTER_MIGRATION_ONLY=false
# No mint authority
FILTER_NO_MINT_AUTHORITY=false
# No freeze authority
FILTER_NO_FREEZE_AUTHORITY=false

# ==================== WHITELIST/BLACKLIST ====================
# Comma-separated wallet addresses
WHITELIST_ADDRESSES=
BLACKLIST_ADDRESSES=

# ==================== LOGGING ====================
LOG_RETENTION_DAYS=30
LOG_MAX_SIZE_MB=10
LOG_BACKUP_COUNT=5
